{
  "rules": [
    {
      "patterns": [
        "^.*/session/.*$",
        "^.*/password/.*$"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": false
      }
    },
    {
      "patterns": [
        "^.*/app$"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": true,
        "presentation": "replace_root"
      }
    },
    {
      "patterns": [
        ".*"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": true
      }
    }
  ]
}
